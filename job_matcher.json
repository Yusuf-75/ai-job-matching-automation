    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  let rawText = item.json.text || \"\";\n  \n  // Markdown entfernen\n  rawText = rawText.replace(/```json/gi, \"\").replace(/```/g, \"\").trim();\n\n  try {\n    const parsedJson = JSON.parse(rawText);\n    \n    // WICHTIG: Wir mischen die KI-Daten mit den Original-Daten (URL, Location etc.)\n    // Wir holen uns die Original-Daten aus dem Input item\n    // Hinweis: In n8n muss man manchmal tricksen, um an die \"parent\" Daten zu kommen.\n    // Aber wir machen es einfach: Wir geben das KI-Ergebnis zurück \n    // UND wir holen uns die URL aus dem Kontext, falls möglich.\n    \n    // Bessere Strategie: Wir mergen das einfach.\n    results.push({\n        json: {\n            ...parsedJson,     // Die Daten von der KI (Score, Titel, Begründung)\n            url: item.json.url // Wir retten die URL aus dem vorherigen Node!\n        }\n    });\n\n  } catch (error) {\n    console.log(\"LLM Fehler (Kein JSON): \", rawText);\n  }\n}\n\nreturn results;"
      },
