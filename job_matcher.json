    {
      "parameters": {
        "jsCode": "const hitList = [];\n\n// Deine strengen Filter\nconst jobRegex = /(werkstudent|student|intern)/i;\nconst ortRegex = /(düsseldorf|dortmund|essen|bochum|nrw|remote|nordrhein-westfalen|köln)/i;\nconst techRegex = /\\b(cloud|aws|azure|ai|genai|artificial intelligence|automation|rpa|n8n|power platform|react|python|salesforce|sap|devops|ki)\\b/i;\n\nconst titleBlacklist = /(sales|vertrieb|marketing|hr|human resources|recruiting|talent|helpdesk|buchhaltung|assistenz|assistant|operations|support|content|webdesign|seo|social media)/i;\nconst descBlacklist = /(first level|1st level|dateneingabe|call center|customer support|kundenanfragen|erstdiagnose|ticketsystem|kundenservice)/i;\n\nfor (const item of $input.all()) {\n    // Apify-spezifische Felder abgreifen (manche Scraper nennen es description, manche jobDescription)\n    const title = (item.json.title || \"\").toLowerCase();\n    const desc = (item.json.description || item.json.jobDescription || \"\").toLowerCase(); \n    const location = (item.json.location || item.json.locationString || \"\").toLowerCase();\n    \n    const fullText = title + \" \" + desc + \" \" + location;\n\n    const isStudent = jobRegex.test(title);\n    const isNRW = ortRegex.test(fullText);\n    const isTech = techRegex.test(fullText);\n    \n    const isTitleBlacklisted = titleBlacklist.test(title);\n    const isDescBlacklisted = descBlacklist.test(fullText);\n\n    // Wenn alles passt, ab auf die Hitliste!\n    if (isStudent && isNRW && isTech && !isTitleBlacklisted && !isDescBlacklisted) {\n        hitList.push(item);\n    }\n}\n\nreturn hitList;"
      },
